# ComplyKit — Docker Compose environment variables
# Copy this file to .env and fill in your values.

# ── Ports ─────────────────────────────────────────────────────────────────────
BACKEND_PORT=8080
UI_PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=complykit

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=changeme

# ── Tenant ────────────────────────────────────────────────────────────────────
ORG_SLUG=myorg
ORG_NAME=My Organisation

# ── AWS ───────────────────────────────────────────────────────────────────────
# Leave AWS_PROFILE=default to use ~/.aws/credentials, or set explicit keys:
AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org-or-user

# ── GCP ───────────────────────────────────────────────────────────────────────
# Application Default Credentials are mounted from ~/.config/gcloud automatically.
# Set GCP_PROJECT_ID to scan a specific project:
GCP_PROJECT_ID=my-gcp-project

# ── Azure ─────────────────────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret

# ── Kubernetes image registry allowlist ───────────────────────────────────────
# Comma-separated prefixes allowed for container images.
# Leave blank to skip the registry allowlist check.
# ALLOWED_REGISTRIES=123456789.dkr.ecr.us-east-1.amazonaws.com,gcr.io/myproject

# ── Build metadata (set automatically by CI) ──────────────────────────────────
# VERSION=1.0.0
# COMMIT=abc1234
# BUILD_DATE=2025-01-01T00:00:00Z
